{
	"type": "module",
	"private": true,
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"build": "tsdown",
		"fix": "run-p 'lint -- --fix' format",
		"lint": "eslint .",
		"format": "prettier . --write",

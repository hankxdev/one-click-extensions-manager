		"unit": "node --test",
		"watch": "tsdown --watch"
	},
	"dependencies": {
		"svelte": "^4.2.20",
		"webext-base-css": "^2.1.0",
		"webext-options-sync": "^4.3.0"
	},
	"devDependencies": {
		"@types/chrome": "^0.1.43",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-config-xo": "^0.52.0",
		"eslint-plugin-svelte": "^3.19.0",
		"npm-run-all2": "^8.0.4",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^3.4.0",
		"rollup": "^4.52.5",
		"rollup-plugin-svelte": "^7.2.3",
		"tsdown": "^0.22.2"
	},
	"webExt": {
		"sourceDir": "distribution",
		"run": {
			"target": [
				"chromium"
			]
